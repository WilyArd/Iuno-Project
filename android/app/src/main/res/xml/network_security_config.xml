<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration untuk Iuno IoT App
  ──────────────────────────────────────────────────
  Tujuan: App ini adalah dashboard IoT jaringan lokal (LAN/home network).
  Broker MQTT (Mosquitto, EMQX, HiveMQ Community, dll) di LAN biasanya
  menggunakan cleartext TCP port 1883 tanpa TLS.

  Karena pengguna bisa menggunakan IP broker apa pun di LAN mereka
  (192.168.x.x, 10.x.x.x, 172.16-31.x.x, dll), kita TIDAK bisa
  mendaftarkan semua kemungkinan IP di domain-config.

  Solusi: izinkan cleartext secara global (base-config), karena:
    1. App ini TIDAK dipakai untuk koneksi internet sensitif.
    2. API eksternal (OpenRouter/OpenAI) sudah menggunakan HTTPS/TLS secara native.
    3. MQTT lokal hampir tidak pernah menggunakan TLS di LAN privat.
-->
<network-security-config>

  <!-- Debug build: tambahkan sertifikat user (untuk Charles Proxy, dll) -->
  <debug-overrides>
    <trust-anchors>
      <certificates src="system" />
      <certificates src="user" />
    </trust-anchors>
  </debug-overrides>

  <!--
    Izinkan cleartext untuk semua koneksi (termasuk IP LAN broker apa pun).
    Ini aman untuk aplikasi IoT lokal karena:
    - MQTT broker berada di LAN privat (tidak exposed ke internet).
    - Koneksi ke API publik (OpenRouter, OpenAI) sudah menggunakan HTTPS.
  -->
  <base-config cleartextTrafficPermitted="true">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>

</network-security-config>

